# Production Environment Variables for Backend API (Task 2.1)
# Copy this to Vercel environment variables dashboard

# Database Configuration
DATABASE_URL=postgresql://user:password@your-host:5432/campaign_db

# JWT Secret (min 32 chars, strong password)
JWT_SECRET=your-super-strong-secret-key-with-mixed-chars-123!@#

# Server Configuration
PORT=4000
NODE_ENV=production

# Database Mode
USE_MOCK_DB=false

# Frontend URL (for CORS)
FRONTEND_URL=https://your-dashboard-domain.vercel.app
